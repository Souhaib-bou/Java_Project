{% extends 'admin/base_admin.html.twig' %}

{% block title %}Plan QR Code{% endblock %}

{% set admin_area = app.request.attributes.get('_route') starts with 'app_admin' %}
{% set plans_route = admin_area ? 'app_admin_plans' : 'app_workspace_plans' %}
{% set tasks_route = admin_area ? 'app_admin_plan_tasks' : 'app_workspace_plan_tasks' %}
{% set public_qr_url = public_qr_base_url ~ path('app_public_plan_qr', {token: plan.qrToken}) %}

{% block admin_content %}
<div class="page-header">
    <h1 class="page-title">Plan QR Code</h1>
    <p class="muted-text">QR code for plan #{{ plan.planId }} assigned to {{ plan.user.firstName }} {{ plan.user.lastName }}.</p>
</div>

<div class="card qr-card">
    <div class="qr-preview">
        <img
            src="https://api.qrserver.com/v1/create-qr-code/?size=260x260&data={{ public_qr_url|url_encode }}"
            alt="QR code for onboarding plan {{ plan.planId }}"
            class="qr-image"
        >
    </div>

    <div class="qr-details">
        <p class="record-eyebrow">QR Token</p>
        <h2 class="section-title">Ready to share</h2>
        <p class="muted-text">This QR now opens a public token-based page showing the plan details, task list, and attachment links for mobile viewing.</p>

        <div class="record-meta">
            <div class="record-meta-item">
                <span class="record-meta-label">Plan</span>
                <span class="record-meta-value">#{{ plan.planId }}</span>
            </div>
            <div class="record-meta-item">
                <span class="record-meta-label">Status</span>
                <span class="record-meta-value">{{ plan.status|replace({'_': ' '})|title }}</span>
            </div>
            <div class="record-meta-item" style="grid-column: 1 / -1;">
                <span class="record-meta-label">Token</span>
                <span class="record-meta-value">{{ plan.qrToken }}</span>
            </div>
            <div class="record-meta-item" style="grid-column: 1 / -1;">
                <span class="record-meta-label">Mobile URL</span>
                <span class="record-meta-value">{{ public_qr_url }}</span>
            </div>
        </div>

        <div class="actions-cell record-actions">
            <a href="{{ path(plans_route) }}" class="btn-secondary">Back to Plans</a>
            <a href="{{ path(tasks_route, {id: plan.planId}) }}" class="btn-primary">Open Tasks</a>
            <a href="{{ public_qr_url }}" target="_blank" rel="noreferrer" class="btn-secondary">Open Public View</a>
        </div>
    </div>
</div>
{% endblock %}
