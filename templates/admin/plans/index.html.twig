{% extends 'admin/base_admin.html.twig' %}

{% block title %}Onboarding Plans{% endblock %}

{% set admin_area = app.request.attributes.get('_route') starts with 'app_admin' %}
{% set plans_route = admin_area ? 'app_admin_plans' : 'app_workspace_plans' %}
{% set new_plan_route = admin_area ? 'app_admin_plans_new' : 'app_workspace_plans_new' %}
{% set edit_plan_route = admin_area ? 'app_admin_plans_edit' : 'app_workspace_plans_edit' %}
{% set tasks_route = admin_area ? 'app_admin_plan_tasks' : 'app_workspace_plan_tasks' %}
{% set delete_plan_route = admin_area ? 'app_admin_plans_delete' : 'app_workspace_plans_delete' %}
{% set qr_route = admin_area ? 'app_admin_plans_qr' : 'app_workspace_plans_qr' %}

{% block admin_content %}
<div class="page-header">
    <h1 class="page-title">{{ viewer_context.candidate ? 'My Onboarding Plans' : 'Onboarding Plans' }}</h1>
    <p class="muted-text">
        {{ viewer_context.candidate
            ? 'Track your onboarding progress, update your plan status, and open the tasks inside each plan.'
            : 'Review assigned plans, spot what needs attention, and open the related task flow quickly.'
        }}
    </p>
</div>

<div class="card card-immersive">
    <div class="section-header">
        <div>
            <h2 class="section-title">Plans Overview</h2>
            <p class="section-kicker">Only the essentials are shown here: owner, status, deadline, tasks, and QR access.</p>
        </div>
        <div class="section-actions">
            {% if viewer_context.canCreatePlans %}
                <a href="{{ path(new_plan_route) }}" class="btn-primary">Add Plan</a>
            {% endif %}
        </div>
    </div>

    <form method="get" action="{{ path(plans_route) }}" class="search-form search-form-panel" data-live-search-form>
        <label for="plans-search" class="search-label">Find a plan</label>
        <div class="search-controls">
            <input
                id="plans-search"
                type="search"
                name="q"
                value="{{ search_term|default('') }}"
                class="search-input"
                autocomplete="off"
                placeholder="Search by plan number, person, email, status, or QR token"
                data-live-search-input
            >
            <input type="hidden" name="case_sensitive" value="{{ case_sensitive ? '1' : '0' }}" data-live-search-case-sensitive>
            <button
                type="button"
                class="search-toggle{{ case_sensitive ? ' active' : '' }}"
                data-live-search-toggle
                aria-pressed="{{ case_sensitive ? 'true' : 'false' }}"
            >
                {{ case_sensitive ? 'Case Sensitive: On' : 'Case Sensitive: Off' }}
            </button>
            <select name="status" class="search-select">
                <option value="">All statuses</option>
                {% for label, value in plan_status_choices %}
                    <option value="{{ value }}" {{ selected_status == value ? 'selected' : '' }}>{{ label }}</option>
                {% endfor %}
            </select>
            <select name="sort" class="search-select">
                <option value="newest" {{ selected_sort == 'newest' ? 'selected' : '' }}>Newest</option>
                <option value="deadline" {{ selected_sort == 'deadline' ? 'selected' : '' }}>Deadline</option>
                <option value="status" {{ selected_sort == 'status' ? 'selected' : '' }}>Status</option>
                <option value="user" {{ selected_sort == 'user' ? 'selected' : '' }}>User name</option>
            </select>
            <label class="search-check">
                <input type="checkbox" name="overdue_only" value="1" {{ overdue_only ? 'checked' : '' }}>
                Overdue only
            </label>
            <button type="button" class="btn-secondary" data-live-search-clear>Clear</button>
            <noscript>
                <button type="submit" class="btn-primary">Search</button>
            </noscript>
        </div>
        <p class="search-hint">Live search refreshes the cards while you type.</p>
    </form>

    <div data-live-search-results>
        {% include 'admin/plans/_results.html.twig' %}
    </div>
</div>
{% endblock %}
