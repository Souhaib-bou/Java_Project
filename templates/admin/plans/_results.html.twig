{% set admin_area = app.request.attributes.get('_route') starts with 'app_admin' %}
{% set edit_plan_route = admin_area ? 'app_admin_plans_edit' : 'app_workspace_plans_edit' %}
{% set tasks_route = admin_area ? 'app_admin_plan_tasks' : 'app_workspace_plan_tasks' %}
{% set delete_plan_route = admin_area ? 'app_admin_plans_delete' : 'app_workspace_plans_delete' %}
{% set qr_route = admin_area ? 'app_admin_plans_qr' : 'app_workspace_plans_qr' %}

<div class="explorer-metrics">
    <div class="explorer-metric-card">
        <span class="explorer-metric-label">Visible plans</span>
        <strong class="explorer-metric-value">{{ plan_metrics.total }}</strong>
    </div>
    <div class="explorer-metric-card">
        <span class="explorer-metric-label">In progress</span>
        <strong class="explorer-metric-value">{{ plan_metrics.active }}</strong>
    </div>
    <div class="explorer-metric-card">
        <span class="explorer-metric-label">Completed</span>
        <strong class="explorer-metric-value">{{ plan_metrics.completed }}</strong>
    </div>
    <div class="explorer-metric-card">
        <span class="explorer-metric-label">Need attention</span>
        <strong class="explorer-metric-value">{{ plan_metrics.overdue }}</strong>
    </div>
</div>

{% if plans is not empty %}
    <div class="record-grid">
        {% for plan in plans %}
            <article class="record-card plan-card">
                <div class="record-card-top">
                    <div class="record-heading">
                        <p class="record-eyebrow">Plan #{{ plan.planId }}</p>
                        <h3 class="record-title">{{ plan.user.firstName }} {{ plan.user.lastName }}</h3>
                        <p class="record-subtitle">{{ plan.user.email ?: 'Assigned candidate' }}</p>
                    </div>
                    <div class="record-chip-stack">
                        <span class="status-pill">{{ plan.status|replace({'_': ' '})|title }}</span>
                        <span class="status-chip {{ plan.isOverdue ? 'overdue' : 'on-track' }}">
                            {{ plan.isOverdue ? 'Overdue' : 'On Track' }}
                        </span>
                    </div>
                </div>

                <div class="record-stats record-stats-plan">
                    <div class="record-stat">
                        <span class="record-stat-label">Deadline</span>
                        <span class="record-stat-value">{{ plan.deadline ? plan.deadline|date('Y-m-d') : 'No deadline' }}</span>
                    </div>
                    <div class="record-stat">
                        <span class="record-stat-label">Tasks</span>
                        <span class="record-stat-value">{{ plan.onboardingtasks|length }} task(s)</span>
                    </div>
                    <div class="record-stat record-stat-wide">
                        <span class="record-stat-label">QR access</span>
                        <span class="record-stat-value">{{ plan.qrToken ? 'Ready' : 'Generate on open' }}</span>
                    </div>
                </div>

                <div class="actions-cell record-actions">
                    {% if viewer_context.canEditPlan(plan) %}
                        <a href="{{ path(edit_plan_route, {id: plan.planId}) }}" class="btn-secondary">
                            {{ viewer_context.canFullyEditPlan(plan) ? 'Edit' : 'Update Status' }}
                        </a>
                    {% endif %}
                    <a href="{{ path(tasks_route, {id: plan.planId}) }}" class="btn-primary">Tasks</a>
                    <a href="{{ path(qr_route, {id: plan.planId}) }}" class="btn-secondary">QR Code</a>
                    {% if viewer_context.canDeletePlan(plan) %}
                        <form method="post" action="{{ path(delete_plan_route, {id: plan.planId}) }}" class="inline-form">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_plan_' ~ plan.planId) }}">
                            <button type="submit" class="btn-danger">Delete</button>
                        </form>
                    {% endif %}
                </div>
            </article>
        {% endfor %}
    </div>
{% else %}
    <div class="empty-state-card">
        {% if search_term is defined and search_term is not empty %}
            <p class="record-eyebrow">No matching plans</p>
            <h3 class="record-title">No plans found for "{{ search_term }}"</h3>
            <p class="muted-text">Try another keyword, change the filters, or clear the search to see all plans again.</p>
        {% else %}
            <p class="record-eyebrow">No plans yet</p>
            <h3 class="record-title">Start your onboarding coordination flow</h3>
            <p class="muted-text">Create the first onboarding plan to assign a user, set a status, and organize plan-specific tasks.</p>
        {% endif %}
    </div>
{% endif %}
