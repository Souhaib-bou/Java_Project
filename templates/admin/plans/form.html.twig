{% extends 'admin/base_admin.html.twig' %}
{% macro render_field(field) %}
    {% if field is defined %}
        <div class="form-field {{ field.vars.errors|length ? 'has-error' : '' }}">
            {{ form_label(field, null, {'label_attr': {'class': 'form-label'}}) }}
            <div class="form-widget">
                {{ form_widget(field, {'attr': {'class': ((field.vars.attr.class|default('') ~ ' form-control')|trim)}}) }}
            </div>
            {% if field.vars.help %}
                <p class="form-help">{{ field.vars.help }}</p>
            {% endif %}
            {% if field.vars.errors|length %}
                <div class="form-error-list">{{ form_errors(field) }}</div>
            {% endif %}
        </div>
    {% endif %}
{% endmacro %}
{% import _self as form_ui %}

{% block title %}{{ page_title }}{% endblock %}

{% set admin_area = app.request.attributes.get('_route') starts with 'app_admin' %}
{% set plans_route = admin_area ? 'app_admin_plans' : 'app_workspace_plans' %}

{% block admin_content %}
<div class="page-header">
    <h1 class="page-title">{{ page_title }}</h1>
    <p class="muted-text">
        {{ limited_editor ? 'Update your plan progress while the protected plan details stay unchanged.' : 'Set the owner, status, and timing for this onboarding plan.' }}
    </p>
</div>

<div class="card card-immersive">
    {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'form-shell'}}) }}
        {% if not form.vars.valid %}
            <div class="form-error-banner">
                <div class="form-error-banner-title">Please review the highlighted fields</div>
                <p class="form-error-banner-text">Some information is missing or invalid. Correct the details below and save again.</p>
                {% if form.vars.errors|length %}
                    <div class="form-error-list">{{ form_errors(form) }}</div>
                {% endif %}
            </div>
        {% endif %}
        {% if limited_editor and plan is defined %}
            <div class="form-note-panel">
                <p class="form-note-title">Plan details are protected</p>
                <p class="form-note-text">Only the current plan status can be updated from this view. Owner, deadline, and QR data remain unchanged.</p>
            </div>
        {% endif %}
        <div class="form-grid">
            {% if form.user is defined %}{{ form_ui.render_field(form.user) }}{% endif %}
            {{ form_ui.render_field(form.status) }}
            {% if form.deadline is defined %}{{ form_ui.render_field(form.deadline) }}{% endif %}
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">Save</button>
            <a href="{{ path(plans_route) }}" class="btn-secondary">Cancel</a>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}
