{% extends 'base.html.twig' %}

{% block title %}Hirely Admin{% endblock %}

{% set admin_area = app.request.attributes.get('_route') starts with 'app_admin' %}

{% block body %}
<div class="admin-shell {{ admin_area ? 'admin-shell-sidebar' : 'admin-shell-workspace' }}">
    {% if admin_area %}
        {% include 'admin/Partials/sidebar.html.twig' %}
    {% endif %}

    <div class="admin-main">
        {% include 'admin/Partials/navbar.html.twig' %}

        <main class="admin-content">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash-message {{ label }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}
            {% block admin_content %}{% endblock %}
        </main>
    </div>
</div>
{% endblock %}
