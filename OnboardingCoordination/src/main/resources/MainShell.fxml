<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<BorderPane fx:id="root"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.MainShellController"
            stylesheets="@styles/hirely.css"
            styleClass="app-root">

    <!-- TOP BAR (UI only) -->
    <top>
        <VBox styleClass="topbar-shell">

            <StackPane styleClass="topbar-wrap">
                <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">

                    <!-- Logo -->
                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="brand">
                        <ImageView fitHeight="34" preserveRatio="true" styleClass="brand-logo">
                            <image>
                                <Image url="@assets/logo-hirely-light.png"/>
                            </image>
                        </ImageView>
                        <Label text="HIRELY" styleClass="brand-text"/>
                    </HBox>

                    <!-- Center nav pills (keep same actions) -->
                    <HBox alignment="CENTER" spacing="10" styleClass="topbar-nav" HBox.hgrow="ALWAYS">
                        <Button text="Home" onAction="#handleOpenHome" styleClass="nav-pill nav-pill-active"/>
                        <Button text="Onboarding" onAction="#handleOpenOnboarding" styleClass="nav-pill"/>
                        <Button text="Job Offers" onAction="#handleOpenJobOffers" styleClass="nav-pill"/>
                    </HBox>

                    <!-- Right icons + profile -->
                    <HBox alignment="CENTER_RIGHT" spacing="10">

                        <StackPane>
                            <!-- Use XML numeric reference to avoid FXML escape issues -->
                            <Button text="&#128276;" styleClass="icon-btn" mnemonicParsing="false"/>
                            <Label text="2" styleClass="badge" StackPane.alignment="TOP_RIGHT"/>
                        </StackPane>

                        <Button text="&#9993;" styleClass="icon-btn" mnemonicParsing="false"/>

                        <!-- Profile dropdown (existing fx:ids kept) -->
                        <Button fx:id="btnUserMenu" styleClass="profile-chip" mnemonicParsing="false">
                            <graphic>
                                <HBox alignment="CENTER" spacing="10">

                                    <StackPane prefWidth="32" prefHeight="32" styleClass="avatar-small">
                                        <ImageView fx:id="imgHeaderAvatar" fitWidth="32" fitHeight="32" preserveRatio="true"/>
                                        <Label fx:id="lblHeaderInitials" text="U" styleClass="user-chip-initials"/>
                                    </StackPane>

                                    <Label fx:id="lblHeaderUserName" text="User" styleClass="profile-name"/>
                                    <Label text="▾" styleClass="profile-caret"/>
                                </HBox>
                            </graphic>
                        </Button>

                    </HBox>

                </HBox>
            </StackPane>

            <!-- Optional page label row (keeps your existing bindings) -->
            <HBox styleClass="page-meta" alignment="CENTER_LEFT" spacing="10">
                <Label fx:id="lblPageTitle" text="Home" styleClass="page-title"/>
                <Label fx:id="lblPageSubtitle" text="Welcome" styleClass="page-subtitle"/>
            </HBox>

        </VBox>
    </top>

    <!-- CONTENT -->
    <center>
        <ScrollPane fx:id="scrollWrapper"
                    fitToWidth="true"
                    hbarPolicy="NEVER">

            <content>

                <StackPane fx:id="contentHost"/>

            </content>
            <padding>
                <Insets top="18" right="18" bottom="18" left="18"/>
            </padding>

        </ScrollPane>
    </center>

</BorderPane>
