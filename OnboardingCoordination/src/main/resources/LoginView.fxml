<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.LoginController"
            stylesheets="@styles/hirely.css"
            styleClass="app-root">

    <center>
        <VBox alignment="CENTER" spacing="16">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <VBox styleClass="card" spacing="14" maxWidth="520">
                <Label text="Welcome back" styleClass="section-title"/>
                <Label text="Sign in to continue" styleClass="form-label"/>

                <GridPane hgap="12" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints minWidth="120" hgrow="NEVER"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>

                    <Label text="Email" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="txtEmail" promptText="name@company.com" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Password" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <PasswordField fx:id="txtPassword" promptText="••••••••" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Button text="Login" onAction="#handleLogin" styleClass="btn-primary"/>
                </HBox>
                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Button text="Create account" onAction="#handleOpenSignup" styleClass="btn-secondary"/>
                </HBox>


                <Label fx:id="lblMsg" text="" styleClass="footer-label"/>
            </VBox>
        </VBox>
    </center>

</BorderPane>
