<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.JobOfferController"
            prefWidth="1920"
            prefHeight="1080"
            style="-fx-background-color: #f4f6fa;">

    <!-- ================= LEFT SIDEBAR ================= -->
    <left>
        <VBox prefWidth="220"
              spacing="20"
              style="-fx-background-color: #1e272e;
                     -fx-padding: 30;">

            <Label text="Hirely"
                   style="-fx-text-fill: white;
                          -fx-font-size: 22px;
                          -fx-font-weight: bold;"/>

            <Separator/>

            <Button text="Job Offers"
                    style="-fx-background-color: #ff5e57;
                           -fx-text-fill: white;
                           -fx-background-radius: 8;
                           -fx-pref-width: 180;"/>

            <Button text="Applications"
                    onAction="#goToApplications"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: white;
                           -fx-border-color: white;
                           -fx-border-radius: 8;
                           -fx-pref-width: 180;"/>

            <Button text="Dashboard"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: white;
                           -fx-pref-width: 180;"/>

        </VBox>
    </left>

    <!-- ================= MAIN CONTENT ================= -->
    <center>
        <VBox spacing="25"
              style="-fx-padding: 40;">

            <!-- TITLE -->
            <Label text="Manage Job Offers"
                   style="-fx-font-size: 28px;
                          -fx-font-weight: bold;"/>

            <!-- FORM CARD -->
            <VBox spacing="20"
                  style="-fx-background-color: white;
                         -fx-padding: 30;
                         -fx-background-radius: 15;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08),15,0,0,4);">

                <GridPane hgap="30" vgap="15">

                    <columnConstraints>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                    </columnConstraints>

                    <!-- Row 0 -->
                    <Label text="Title:" GridPane.rowIndex="0"/>
                    <TextField fx:id="titleField"
                               GridPane.rowIndex="0"
                               GridPane.columnIndex="1"/>

                    <Label text="Contract:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                    <ComboBox fx:id="contractTypeBox"
                              GridPane.rowIndex="0"
                              GridPane.columnIndex="3"/>

                    <!-- Row 1 -->
                    <Label text="Salary:" GridPane.rowIndex="1"/>
                    <TextField fx:id="salaryField"
                               GridPane.rowIndex="1"
                               GridPane.columnIndex="1"/>

                    <Label text="Experience:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                    <TextField fx:id="experienceField"
                               GridPane.rowIndex="1"
                               GridPane.columnIndex="3"/>

                    <!-- Row 2 -->
                    <Label text="Location:" GridPane.rowIndex="2"/>
                    <TextField fx:id="locationField"
                               GridPane.rowIndex="2"
                               GridPane.columnIndex="1"/>

                    <Label text="Status:" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                    <ComboBox fx:id="statusBox"
                              GridPane.rowIndex="2"
                              GridPane.columnIndex="3"/>

                    <!-- Row 3 -->
                    <Label text="Publication Date:" GridPane.rowIndex="3"/>
                    <DatePicker fx:id="publicationDatePicker"
                                GridPane.rowIndex="3"
                                GridPane.columnIndex="1"/>

                    <Label text="Description:" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
                    <TextArea fx:id="descriptionField"
                              prefRowCount="2"
                              GridPane.rowIndex="3"
                              GridPane.columnIndex="3"/>
                </GridPane>

                <!-- BUTTONS -->
                <HBox spacing="20">
                    <Button text="Add"
                            onAction="#addJobOffer"
                            style="-fx-background-color: #27ae60;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 8;"/>

                    <Button text="Update"
                            onAction="#updateJobOffer"
                            style="-fx-background-color: #f39c12;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 8;"/>


                </HBox>
            </VBox>

            <!-- TABLE CARD -->
            <VBox spacing="15"
                  VBox.vgrow="ALWAYS"
                  style="-fx-background-color: white;
                         -fx-padding: 30;
                         -fx-background-radius: 15;">

                <Label text="Job Listings"
                       style="-fx-font-size: 20px;
                              -fx-font-weight: bold;"/>

                <TableView fx:id="tableView"
                           VBox.vgrow="ALWAYS">

                    <columns>
                        <TableColumn fx:id="colId" text="ID"/>
                        <TableColumn fx:id="colUserId" text="User ID" />
                        <TableColumn fx:id="colTitle" text="Title"/>
                        <TableColumn fx:id="colContract" text="Contract"/>
                        <TableColumn fx:id="colSalary" text="Salary"/>
                        <TableColumn fx:id="colExperience" text="Experience"/>
                        <TableColumn fx:id="colLocation" text="Location"/>
                        <TableColumn fx:id="colStatus" text="Status"/>
                        <TableColumn fx:id="colAction" text="Action" prefWidth="120"/>
                    </columns>

                </TableView>
            </VBox>

        </VBox>
    </center>

</BorderPane>