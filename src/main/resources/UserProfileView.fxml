<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controllers.UserProfileController"
      spacing="14"
      styleClass="app-root">

    <padding>
        <Insets top="0" right="0" bottom="0" left="0"/>
    </padding>

    <VBox styleClass="card" spacing="12" maxWidth="760">
        <Label text="My Profile" styleClass="section-title"/>

        <GridPane hgap="12" vgap="10">
            <columnConstraints>
                <ColumnConstraints minWidth="120" hgrow="NEVER"/>
                <ColumnConstraints hgrow="ALWAYS"/>
                <ColumnConstraints minWidth="120" hgrow="NEVER"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="First name" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="txtFirstName" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Last name" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
            <TextField fx:id="txtLastName" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

            <Label text="Email" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="txtEmail" GridPane.rowIndex="1" GridPane.columnIndex="1" GridPane.columnSpan="3"/>

            <Label text="Password" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <PasswordField fx:id="txtPassword" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="Status" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
            <TextField fx:id="txtStatus" editable="false" GridPane.rowIndex="2" GridPane.columnIndex="3"/>
        </GridPane>

        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Button text="Back" onAction="#handleBack" styleClass="btn-secondary"/>
            <Button text="Save Changes" onAction="#handleSave" styleClass="btn-primary"/>
            <Button text="Delete Account" onAction="#handleDeleteAccount" styleClass="btn-danger"/>
            <Button text="Deactivate Account"
                    onAction="#handleDeactivateAccount"
                    styleClass="btn-danger"/>
        </HBox>

        <Label fx:id="lblMsg" text="" styleClass="footer-label"/>
    </VBox>

</VBox>
