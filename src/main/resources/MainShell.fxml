<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="root"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.MainShellController"
            stylesheets="@styles/hirely.css"
            styleClass="app-root">

    <!-- HEADER -->
    <top>
        <VBox styleClass="header-shell">

            <!-- TOP ROW -->
            <HBox styleClass="header-top" alignment="CENTER_LEFT" spacing="12">

                <Label text="Hirely" styleClass="header-app-title"/>

                <!-- NAV BUTTONS -->
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Button text="Home" onAction="#handleOpenHome" styleClass="btn-secondary"/>
                    <Button text="Onboarding" onAction="#handleOpenOnboarding" styleClass="btn-primary"/>
                    <Button text="Job Offers" onAction="#handleOpenJobOffers" styleClass="btn-secondary"/>
                </HBox>

                <Pane HBox.hgrow="ALWAYS"/>

                <!-- profile dropdown -->
                <MenuButton fx:id="menuUser"
                            styleClass="user-chip-menu"
                            popupSide="BOTTOM"
                            mnemonicParsing="false">

                    <graphic>
                        <HBox alignment="CENTER" spacing="10">
                            <Label fx:id="lblHeaderInitials" text="U" styleClass="user-chip-initials"/>
                            <Label fx:id="lblHeaderUserName" text="User" styleClass="user-chip-name"/>
                            <Label text="▾" styleClass="user-chip-caret"/>
                        </HBox>
                    </graphic>

                    <items>
                        <MenuItem text="Profile" onAction="#handleOpenProfile"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="Logout" onAction="#handleLogout"/>
                    </items>
                </MenuButton>
            </HBox>

            <!-- BOTTOM ROW -->
            <HBox styleClass="header-bottom" alignment="CENTER_LEFT" spacing="12">
                <Label fx:id="lblPageTitle" text="Home" styleClass="header-title"/>
                <Label fx:id="lblPageSubtitle" text="Welcome" styleClass="header-subtitle"/>
            </HBox>

            <Region styleClass="header-accent"/>
        </VBox>
    </top>

    <!-- CONTENT -->
    <center>
        <StackPane fx:id="contentHost">
            <padding>
                <Insets top="18" right="18" bottom="18" left="18"/>
            </padding>
        </StackPane>
    </center>

</BorderPane>
