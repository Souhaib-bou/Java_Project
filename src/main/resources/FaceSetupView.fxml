<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controllers.FaceSetupController"
            stylesheets="@styles/hirely.css">

    <center>
        <VBox alignment="CENTER" spacing="0">
            <VBox styleClass="card" spacing="16" maxWidth="660">

                <Label text="Setup Face ID" styleClass="section-title"/>
                <Label text="Look at the camera and click Capture when your face is clearly visible."
                       styleClass="form-label" wrapText="true"/>

                <ImageView fx:id="webcamView" fitWidth="620" fitHeight="460"
                           preserveRatio="true" styleClass="webcam-preview"/>

                <HBox alignment="CENTER_RIGHT" spacing="12">
                    <Button text="Close"        onAction="#handleClose"   styleClass="btn-secondary"/>
                    <Button text="Capture Face" onAction="#handleCapture" styleClass="btn-primary"/>
                </HBox>

                <Label fx:id="lblStatus" text="Initializing camera…" styleClass="footer-label"/>

            </VBox>
        </VBox>
    </center>

</BorderPane>
