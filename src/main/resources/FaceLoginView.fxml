<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controllers.FaceLoginController"
            stylesheets="@styles/hirely.css">

    <center>
        <VBox alignment="CENTER" spacing="0">
            <VBox styleClass="card" spacing="16" maxWidth="660">

                <Label text="Face Login" styleClass="section-title"/>
                <Label text="Look at the camera. You will be logged in automatically when your face is recognized."
                       styleClass="form-label" wrapText="true"/>

                <ImageView fx:id="webcamView" fitWidth="620" fitHeight="440"
                           preserveRatio="true"/>

                <HBox alignment="CENTER_RIGHT" spacing="12">
                    <Button text="Cancel" onAction="#handleCancel" styleClass="btn-secondary"/>
                </HBox>

                <Label fx:id="lblStatus" text="Scanning…" styleClass="footer-label"/>

            </VBox>
        </VBox>
    </center>

</BorderPane>
